---
const { faqs, heading = 'Frequently asked questions' } = Astro.props;
---
<section class="section faq-sec">
  <div class="shell">
    <div class="sec-head"><p class="eyebrow">FAQ</p><h2>{heading}</h2></div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>
