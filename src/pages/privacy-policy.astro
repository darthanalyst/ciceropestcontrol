---
import Base from '../layouts/Base.astro';
import site from '../data/site.js';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { breadcrumbNode } from '../lib/schema.js';
const trail = [{ name: 'Home', path: '/' }, { name: 'Privacy Policy', path: '/privacy-policy/' }];
const nodes = [breadcrumbNode(trail)];
---
<Base title="Privacy Policy | Cicero Pest Control" description="How Cicero Pest Control handles information. We collect no data through this website; the only action is a phone call." canonical="/privacy-policy/" nodes={nodes}>
  <section class="subhead"><div class="shell">
    <p class="eyebrow">Legal</p>
    <h1>Privacy Policy</h1>
  </div></section>
  <Breadcrumbs trail={trail} />
  <section class="section"><div class="shell narrow prose">
    <p class="lede">Cicero Pest Control keeps this simple. This website does not collect personal information. There are no forms, no accounts, and no email capture. The only action offered here is a phone call.</p>
    <h2>Information we do not collect</h2>
    <p>Because the site has no contact form, quote form, or login, we do not gather names, addresses, or email addresses through it. If you choose to call the phone number listed on the site, any information you share on that call is handled by the party who answers, and any calls may be routed to a participating provider.</p>
    <h2>Basic site analytics</h2>
    <p>Like most websites, standard server and hosting logs may record non-identifying technical details such as browser type and pages requested. This information is used only to keep the site working and is not used to identify individual visitors.</p>
    <h2>Third-party links</h2>
    <p>Some pages link to outside references such as public-health and university resources. Those sites have their own privacy practices, and we are not responsible for their content or handling of information.</p>
    <h2>Contact</h2>
    <p>Questions about this policy can be raised by calling {site.phone}.</p>
  </div></section>
</Base>
